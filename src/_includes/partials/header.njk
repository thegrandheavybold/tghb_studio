<header>

  <div class="wrapper">

    <div class="header_bar">

      <div class="header_bar__left">

        <nav id="site-navigation" class="main-navigation">

          <button class="menu-toggle" aria-controls="primary-menu" aria-expanded="false" aria-label="Open the main menu">
            <div class="hamburger">
              <span></span>
            </div>
          </button>

        

        </nav><!-- #site-navigation -->

        <h1 class="h6 tghb_subline">{{ site.name }} <span>{{ i18n[locale].header.subline }}</span></h1>

      </div><!-- .header_bar__left -->

      <div class="site-branding">
        <a id="logo"
          href="{% if locale == 'de' %}/de/{% else %}/{% endif %}"
          rel="home"
          title="TheGrandHeavyBold Studio"
          aria-label="This is the Logo of TheGrandHeavyBold Studio">
          <svg class="tghb_logo" aria-hidden="true">
            <use xlink:href="#tghb_logo"></use>
          </svg>
        </a>
      </div><!-- .site-branding -->

    </div><!-- .header_bar -->

  </div><!-- .wrapper -->

</header>

<div class="menu">

            <div class="wrapper">

              <div class="menu__content">

                <div class="menu__items">

                  <ul class="menu__links">
                    <li>
                      <a href="{{ 'projects' | nav_url(locale) }}">
                        {{ i18n[locale].nav.projects }}
                      </a>
                    </li>

                    <li>
                      <a href="{{ 'services' | nav_url(locale) }}">
                        {{ i18n[locale].nav.services }}
                      </a>
                    </li>

                    <li>
                      <a href="{{ 'studio' | nav_url(locale) }}">
                        {{ i18n[locale].nav.studio }}
                      </a>
                    </li>

                    <li>
                      <a href="{{ 'nevernotcooking' | nav_url(locale) }}" class="menu__nnc-link">
                        {{ i18n[locale].nav.nevernotcooking }}
                      </a>
                    </li>
                  </ul>

                  {%- include "partials/language_switcher.njk" -%}

                </div><!-- .menu__items -->

                <div class="menu__info">

                  <ul class="footer__adress">
                    <li><strong>{{ i18n[locale].footer.locations.ffm.title }}</strong></li>
                    <li>{{ i18n[locale].footer.locations.ffm.street }} {{ i18n[locale].footer.locations.ffm.number }}</li>
                    <li>{{ i18n[locale].footer.locations.ffm.postcode }} {{ i18n[locale].footer.locations.ffm.city }}</li>
                    <li><a href="tel:{{ i18n[locale].footer.locations.ffm.phone }}">{{ i18n[locale].footer.locations.ffm.phone }}</a></li>
                  </ul>

                  <ul class="footer__adress">
                    <li><strong>{{ i18n[locale].footer.locations.cgn.title }}</strong></li>
                    <li>{{ i18n[locale].footer.locations.cgn.street }} {{ i18n[locale].footer.locations.cgn.number }}</li>
                    <li>{{ i18n[locale].footer.locations.cgn.postcode }} {{ i18n[locale].footer.locations.cgn.city }}</li>
                    <li><a href="tel:{{ i18n[locale].footer.locations.cgn.phone }}">{{ i18n[locale].footer.locations.cgn.phone }}</a></li>
                  </ul>

                  <ul class="footer__social">
                    <li><a href="https://www.linkedin.com/company/thegrandheavybold/" target="_blank" rel="noopener" >LinkedIn</a></li>
                  </ul>

                  <ul class="footer__social">
                    <li><a href="https://instagram.com/tghb.studio" target="_blank" rel="noopener">Instagram</a></li>
                    <li><a href="https://www.facebook.com/tghb.studio/" target="_blank" rel="noopener">Facebook</a></li>
                    <li><a href="https://twitter.com/tghbstudio/" target="_blank" rel="noopener">Twitter</a></li>
                    <li><a href="https://www.behance.net/TheGrandHeavyBold" target="_blank" rel="noopener">Behance</a></li>
                  </ul>

                </div><!-- .menu__info -->

              </div><!-- .menu__content -->

            </div><!-- .wrapper -->

          </div><!-- .menu -->
