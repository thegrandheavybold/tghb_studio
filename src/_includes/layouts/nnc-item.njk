---
layout: layouts/base.njk
---

<section class="nnc-post">
  <div class="wrapper">
    {% if locale == "de" %}
      {% set galleryUrl = "/de/nevernotcooking/" %}
    {% else %}
      {% set galleryUrl = "/nevernotcooking/" %}
    {% endif %}

    <script>
      (function () {
        if (typeof window === "undefined") return;

        var galleryUrl = {{ galleryUrl | dump | safe }};
        var slug = {{ page.fileSlug | dump | safe }};
        var target = new URL(galleryUrl, window.location.origin);

        target.searchParams.set("lightbox", slug);
        window.location.replace(target.toString());
      })();
    </script>

    <h1>{{ title }}</h1>

    {% for item in media %}
      {% if item.type == "image" %}
        {% set imageSrc = (item.src or "") | replace("assets/img/", "") | replace("/assets/img/", "") %}
        {% set imageUrl = "/assets/img/" + imageSrc %}
        <img
          src="/.netlify/images?url={{ imageUrl }}&w=1600"
          alt="{{ item.alt }}"
        >
      {% endif %}
    {% endfor %}

    {% if description %}
      <div class="nnc-post__description">{{ description | markdown | safe }}</div>
    {% endif %}

    {% if hashtags %}
      <ul class="tags">
        {% for tag in hashtags %}
          {% set normalizedTag = (tag or "") | replace("#", "") | trim %}
          {% if normalizedTag %}
            <li>#{{ normalizedTag }}</li>
          {% endif %}
        {% endfor %}
      </ul>
    {% endif %}

  </div>
</section>
