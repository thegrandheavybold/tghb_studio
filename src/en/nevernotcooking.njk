<section class="nnc-feed-shell">
  <div class="wrapper_w_img">

    {# --- NNC Collection --- #}
    {% set nncCollection = collections["nevernotcooking_" + locale] %}

    {# --- Detect serve/dev --- #}
    {% set isDev = (eleventy and eleventy.env and eleventy.env.runMode == "serve") %}

    <ul class="nnc-feed">
    {% for post in nncCollection %}
      <li class="nnc-item mix {{ post.data.filters | join(' ') }}" data-animate="fade-up">
        {% set firstMedia = post.data.media[0] %}

        <a href="{{ post.url }}" class="nnc-trigger" data-index="{{ loop.index0 }}" data-no-transition>
          <figure class="nnc-figure">

            {% if firstMedia.type == "image" %}
              {% set imageSrc = (firstMedia.src or "") | replace("/assets/img/", "") | replace("assets/img/", "") %}

              {% if isDev %}
                {# ✅ LOCAL DEV: use plain local image (no netlify image CDN) #}
                <img
                  src="/assets/img/{{ imageSrc }}"
                  alt="{{ firstMedia.alt or post.data.title }}"
                  loading="lazy"
                  decoding="async"
                >
              {% else %}
                {# ✅ PRODUCTION: use Netlify Image CDN #}
                <picture>
                  <source
                    type="image/avif"
                    srcset="
                      /.netlify/images?url=/assets/img/{{ imageSrc }}&w=320&fm=avif 320w,
                      /.netlify/images?url=/assets/img/{{ imageSrc }}&w=640&fm=avif 640w,
                      /.netlify/images?url=/assets/img/{{ imageSrc }}&w=900&fm=avif 900w
                    "
                    sizes="(min-width:1440px) 16vw, (min-width:1024px) 20vw, (min-width:768px) 25vw, 50vw"
                  >
                  <source
                    type="image/webp"
                    srcset="
                      /.netlify/images?url=/assets/img/{{ imageSrc }}&w=320&fm=webp 320w,
                      /.netlify/images?url=/assets/img/{{ imageSrc }}&w=640&fm=webp 640w,
                      /.netlify/images?url=/assets/img/{{ imageSrc }}&w=900&fm=webp 900w
                    "
                    sizes="(min-width:1440px) 16vw, (min-width:1024px) 20vw, (min-width:768px) 25vw, 50vw"
                  >
                  <img
                    src="/.netlify/images?url=/assets/img/{{ imageSrc }}&w=640"
                    alt="{{ firstMedia.alt or post.data.title }}"
                    loading="lazy"
                    decoding="async"
                  >
                </picture>
              {% endif %}

            {% elseif firstMedia.type == "video" %}
              {% set videoPoster = (firstMedia.poster or "") | replace("/assets/img/", "") | replace("assets/img/", "") %}
              {% set videoPreview = (firstMedia.preview or "") | replace("/assets/video/", "") | replace("assets/video/", "") %}

              {# Video preview stays local in dev and prod (your assets/video) #}
              <video
                class="nnc-video-preview"
                muted
                loop
                playsinline
                preload="metadata"
                poster="/assets/img/{{ videoPoster }}"
              >
                <source src="/assets/video/{{ videoPreview }}" type="video/mp4">
              </video>

            {% endif %}

          </figure>
        </a>
      </li>
    {% endfor %}
    </ul>
  </div>
</section>


{# 🔥 Data Bridge for Lightbox #}
<script>
  window.NNC_ITEMS = [
  {% for item in nncCollection %}
    {
      url: "{{ item.url }}",
      title: {{ item.data.title | dump | safe }},
      description: {{ (item.data.description or "") | dump | safe }},
      descriptionHtml: {{ ((item.data.description or "") | markdown) | dump | safe }},
      tags: {{ (item.data.hashtags or []) | dump | safe }},
      media: {{ (item.data.media or []) | dump | safe }}
    }{% if not loop.last %},{% endif %}
  {% endfor %}
  ];
</script>

<div class="nnc-lightbox" id="nncLightbox" data-gallery-url="{{ page.url }}" hidden>
  <div class="nnc-lightbox__inner">

    <button class="nnc-lightbox__close menu-toggle" type="button" aria-label="Close lightbox" aria-expanded="false">
      <div class="hamburger" aria-hidden="true">
        <span></span>
      </div>
    </button>

    <div class="nnc-lightbox__media-wrapper">
      <button class="nnc-lightbox__nav nnc-lightbox__prev" aria-label="Previous media">‹</button>
      <div class="nnc-lightbox__media"></div>
      <button class="nnc-lightbox__nav nnc-lightbox__next" aria-label="Next media">›</button>
    </div>

    <div class="nnc-lightbox__meta">
      <h2 class="nnc-lightbox__title"></h2>
      <div class="nnc-lightbox__description"></div>
      <div class="nnc-lightbox__tags"></div>
    </div>

  </div>
</div>
