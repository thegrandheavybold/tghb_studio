    "moment": "^2.30.1",
    "netlify-cli": "^17.37.2",
    "netlify-cms": "^2.10.192",
    "normalize.css": "^8.0.1",
    "require-dir": "^1.2.0",
    "swiper": "^11.1.15"
  },
  "devDependencies": {
    "@11ty/eleventy": "^3.0.0",
